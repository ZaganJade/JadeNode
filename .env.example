# JadeNode Monorepo Environment
# Copy this file to .env and fill in values

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jadenode
DB_USERNAME=jadenode
DB_PASSWORD=secret

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Docker Infrastructure
COMPOSE_PROJECT_NAME=jadenode

# MinIO / Cloudflare R2
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=jadenode
AWS_ENDPOINT=http://127.0.0.1:9000

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# Resend (Email)
RESEND_API_KEY=
